generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
}

enum ProjectStatus {
  LEAD
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  PENDING
  SIGNED
  CANCELLED
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())

  projects Project[]
}

model Client {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  document String @unique // CPF ou CNPJ
  email    String @unique
  phone    String

  projects Project[]
}

model Project {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  status      ProjectStatus @default(LEAD)
  totalValue  Float
  createdAt   DateTime      @default(now())

  client    Client @relation(fields: [clientId], references: [id])
  clientId  String @db.ObjectId
  manager   User   @relation(fields: [managerId], references: [id])
  managerId String @db.ObjectId

  contracts Contract[]
  payments  Payment[]
}

model Contract {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  status    ContractStatus @default(DRAFT)
  value     Float
  startDate DateTime
  endDate   DateTime
  fileUrl   String? // PDF do contrato
  createdAt DateTime       @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.ObjectId

  payments Payment[]
}

model Payment {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  value   Float
  dueDate DateTime
  paidAt  DateTime?
  paid    Boolean   @default(false)
  type    String // "INCOME" | "EXPENSE"

  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String    @db.ObjectId
  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?   @db.ObjectId
}
